# Required
# Sign the session cookie (any long random string).
SESSION_SECRET=generate-a-long-random-secret-here
# Encrypt credential presets at rest (AES-256-GCM). MUST decode to 32 bytes
# (base64 of 32 bytes, OR a raw 32-byte string). Generate with, e.g.:
#   openssl rand -base64 32
MASTER_KEY=replace-with-32-bytes-base64

# First-run admin bootstrap (creates an admin with must_change_password=1).
# No-op on later restarts once an admin exists, so these can be blank then.
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# Default outbound Anthropic credential (optional — per-user credentials are
# managed in the admin panel; this is the fallback for the root admin shell).
ANTHROPIC_AUTH_TOKEN=your-anthropic-token
# or: ANTHROPIC_API_KEY=sk-ant-...

# Optional gateway
# ANTHROPIC_BASE_URL=http://127.0.0.1:15721

# Proxy (http:// or socks5://) — leave blank for direct. Opt-in via the
# dedicated CLAUDE_*_PROXY names. The generic HTTP_PROXY / ALL_PROXY names are
# deliberately NOT read: they are what the host leaks into the server's own env
# via docker run -e / env_file, and re-injecting them into the PTY crashes
# claude's Node socks layer on a fresh OAuth handshake (ERR_ASSERTION).
# CLAUDE_HTTP_PROXY=http://host.docker.internal:7890
# CLAUDE_HTTPS_PROXY=http://host.docker.internal:7890
# CLAUDE_ALL_PROXY=socks5://host.docker.internal:1080
CLAUDE_NO_PROXY=localhost,127.0.0.1

API_TIMEOUT_MS=600000

# Cookie SameSite for the session cookie. "none" (default) works behind
# Cloudflare/nginx/HTTPS; use "lax" for local http://localhost dev.
# COOKIE_SAMESITE=none
